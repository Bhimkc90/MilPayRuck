<!DOCTYPE html>
<html>
<head>
    <title>Budget - MilPayRuck</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav>
    <a href="/dashboard">Dashboard</a>
    <a href="/profile">Profile</a>
    <a href="/budget">Budget</a>
    <a href="/transactions">Transactions</a>
    <a href="/pay-calculator">Pay Calculator</a>
    <a href="/logout">Logout</a>
</nav>

<div class="container">
    <h1>Budget</h1>

    <a href="/edit-budget">Edit Budget</a>

    <br><br>

    <p><strong>Monthly Income:</strong> $<%= income %></p>

    <% if (expenses) { %>
        <table>
            <tr>
                <th>Category</th>
                <th>Amount</th>
            </tr>

            <tr>
                <td>Rent / Mortgage</td>
                <td>$<%= expenses.rentMortgage || 0 %></td>
            </tr>

            <tr>
                <td>Utilities</td>
                <td>$<%= expenses.utilities || 0 %></td>
            </tr>

            <tr>
                <td>Transportation</td>
                <td>$<%= expenses.transportation || 0 %></td>
            </tr>

            <tr>
                <td>Groceries</td>
                <td>$<%= expenses.groceries || 0 %></td>
            </tr>

            <tr>
                <td>Dining Out</td>
                <td>$<%= expenses.diningOut || 0 %></td>
            </tr>

            <tr>
                <td>Insurance</td>
                <td>$<%= expenses.insurance || 0 %></td>
            </tr>

            <tr>
                <td>Savings</td>
                <td>$<%= expenses.savings || 0 %></td>
            </tr>

            <tr>
                <td>Investments</td>
                <td>$<%= expenses.investments || 0 %></td>
            </tr>

            <tr>
                <td>Entertainment</td>
                <td>$<%= expenses.entertainment || 0 %></td>
            </tr>

            <tr>
                <td>Miscellaneous</td>
                <td>$<%= expenses.miscellaneous || 0 %></td>
            </tr>
        </table>
    <% } else { %>
        <p>No budget found.</p>
        <a href="/edit-budget">Create Budget</a>
    <% } %>
</div>

</body>
</html>