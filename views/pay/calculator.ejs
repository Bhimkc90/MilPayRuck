<!DOCTYPE html>
<html>
<head>
    <title>Pay Calculator - MilPayRuck</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav>
    <a href="/dashboard">Dashboard</a>
    <a href="/profile">Profile</a>
    <a href="/budget">Budget</a>
    <a href="/transactions">Transactions</a>
    <a href="/pay-calculator">Pay Calculator</a>
    <a href="/logout">Logout</a>
</nav>

<div class="container">

    <h1>Military Pay Calculator</h1>
    <p>Estimate monthly military pay based on rank, time in service, ZIP code, and dependency status.</p>

    <form action="/pay-calculator" method="POST">

        <select name="rank" required>
            <option value="">Select Rank</option>
        
            <option value="E1">E1</option>
            <option value="E2">E2</option>
            <option value="E3">E3</option>
            <option value="E4">E4</option>
            <option value="E5">E5</option>
            <option value="E6">E6</option>
            <option value="E7">E7</option>
            <option value="E8">E8</option>
            <option value="E9">E9</option>
        
            <option value="W1">W1</option>
            <option value="W2">W2</option>
            <option value="W3">W3</option>
            <option value="W4">W4</option>
            <option value="W5">W5</option>
        
            <option value="O1">O1</option>
            <option value="O2">O2</option>
            <option value="O3">O3</option>
            <option value="O4">O4</option>
            <option value="O5">O5</option>
            <option value="O6">O6</option>
            <option value="O7">O7</option>
            <option value="O8">O8</option>
            <option value="O9">O9</option>
            <option value="O10">O10</option>
        </select>

        <br><br>

        <select name="dependents" required>
            <option value="yes" <%= typeof profile !== 'undefined' && profile && profile.dependents > 0 ? 'selected' : '' %>>
                With Dependents
            </option>
        
            <option value="no" <%= typeof profile !== 'undefined' && profile && profile.dependents === 0 ? 'selected' : '' %>>
                Without Dependents
            </option>
        </select>

        <br><br>

        <button type="submit">Calculate Pay</button>

    </form>

    <% if (typeof result !== "undefined") { %>

        <hr>

        <h2>Pay Estimate</h2>

        <p><strong>Rank:</strong> <%= result.rank %></p>
        <p><strong>Years of Service:</strong> <%= result.timeInService %></p>
        <p><strong>ZIP Code:</strong> <%= result.zipCode %></p>
        <p><strong>Dependents:</strong> <%= result.dependents %></p>

        <p><strong>Base Pay:</strong> $<%= result.basePay %></p>
        <p><strong>BAS:</strong> $<%= result.bas %></p>
        <p><strong>BAH:</strong> $<%= result.bah %></p>

        <h3>Gross Monthly Pay: $<%= result.grossMonthlyPay %></h3>

    <% } %>

</div>

</body>
</html>