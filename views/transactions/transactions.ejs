<!DOCTYPE html>
<html>
<head>
    <title>Transactions - MilPayRuck</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <nav>
        <a href="/dashboard">Dashboard</a>
        <a href="/profile">Profile</a>
        <a href="/budget">Budget</a>
        <a href="/transactions">Transactions</a>
        <a href="/add-transaction">Add Transaction</a>
    </nav>

    <div class="container">

        <h1>Transactions</h1>
        <p>Your recent income and expense activity.</p>

        <table border="1" cellpadding="10">
            <tr>
                <th>Category</th>
                <th>Amount</th>
                <th>Type</th>
                <th>Description</th>
                <th>Date</th>
                <th>Action</th>
            </tr>

            <% transactions.forEach(transaction => { %>
                <tr>
                    <td><%= transaction.category %></td>
                    <td>$<%= transaction.amount %></td>
                    <td><%= transaction.type %></td>
                    <td><%= transaction.description %></td>
                    <td><%= transaction.transactionDate.toDateString() %></td>

                    <td>
                        <form action="/delete-transaction/<%= transaction._id %>" method="POST">
                            <button type="submit">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            <% }) %>

        </table>

    </div>

</body>
</html>