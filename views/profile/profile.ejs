<!DOCTYPE html>
<html>
<head>
    <title>Profile - MilPayRuck</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav>
    <a href="/dashboard">Dashboard</a>
    <a href="/profile">Profile</a>
    <a href="/budget">Budget</a>
    <a href="/transactions">Transactions</a>
    <a href="/pay-calculator">Pay Calculator</a>
    <a href="/ai-coach">AI Coach</a>
    <a href="/logout">Logout</a>
</nav>

<div class="container">
    <h1>Profile</h1>

    <% if (profile) { %>
        <p><strong>Branch:</strong> US Army</p>
        <p><strong>Rank:</strong> <%= profile.rank %></p>
        <p><strong>Time in Service:</strong> <%= profile.timeInService %> years</p>
        <p><strong>Marital Status:</strong> <%= profile.maritalStatus %></p>
        <p><strong>Dependents:</strong> <%= profile.dependents %></p>
        <p><strong>Duty Location:</strong> <%= profile.dutyLocation %></p>

        <br>
        <a href="/edit-profile">Edit Profile</a>
    <% } else { %>
        <p>No profile found.</p>
        <a href="/edit-profile">Create Profile</a>
    <% } %>
</div>

</body>
</html>