<!DOCTYPE html>
<html>
<head>
    <title>MilPayRuck</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="home-page">

    <div class="container">

        <h1>MilPayRuck</h1>

        <p class="hero-text">
            A Military Pay Calculator and Financial Planning Tool designed
            to help service members estimate pay, manage budgets, track
            expenses, and improve financial readiness.
        </p>

        <div class="buttons">

            <a href="/register?type=military">
                <button>Get Started</button>
            </a>

            <a href="/login">
                <button>Login</button>
            </a>

        </div>

        <hr>

        <h2>Features</h2>

        <div class="dashboard-grid">

            <div class="card">
                <h3>Military Pay Calculator</h3>
                <p>
                    Estimate military compensation using rank,
                    BAH, BAS, and dependent status.
                </p>
            </div>

            <div class="card">
                <h3>Budget Planning</h3>
                <p>
                    Build monthly budgets and track
                    financial goals.
                </p>
            </div>

            <div class="card">
                <h3>Transaction Tracking</h3>
                <p>
                    Record income and expenses to monitor
                    spending habits.
                </p>
            </div>

            <div class="card">
                <h3>Financial Dashboard</h3>
                <p>
                    View income, expenses, savings rate,
                    and remaining cash in one place.
                </p>
            </div>

        </div>

    </div>

</div>

</body>
</html>