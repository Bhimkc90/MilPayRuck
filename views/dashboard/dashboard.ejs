<!DOCTYPE html>
<html>
<head>
    <title>Dashboard - MilPayRuck</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <nav>
        <a href="/dashboard">Dashboard</a>
        <a href="/profile">Profile</a>
        <a href="/budget">Budget</a>
        <a href="/transactions">Transactions</a>
        <a href="/logout">Logout</a>    
    </nav>

    <div class="container">

        <h1>MilPayRuck Dashboard</h1>

        <div class="dashboard-grid">

            <div class="card">
                <h2>Monthly Net Income</h2>
                <p>$<%= income %></p>
            </div>

            <div class="card">
                <h2>Total Expenses</h2>
                <p>$<%= totalExpenses %></p>
            </div>

            <div class="card">
                <h2>Remaining Cash</h2>
                <p>$<%= remainingCash %></p>
            </div>

            <div class="card">
                <h2>Savings Rate</h2>
                <p><%= savingsRate %>%</p>
            </div>

        </div>

    </div>

</body>
</html>